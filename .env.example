# -- Oracle Container Registry (OCIR) --------------------------------------
# Used by scripts/release.sh to publish the built image.
# Region key and tenancy namespace are hard-defaulted in release.sh to the
# tlanticwfm tenancy in Frankfurt; override here only if pushing elsewhere.
OCI_REGION=fra
OCI_TENANCY_NAMESPACE=frsxihvekg43
# IAM user (e.g. andre.pinto@tlantic.com). The script prepends the
# tenancy namespace automatically if you don't include it.
OCIR_USERNAME=
# Oracle Cloud Auth Token (NOT the console password).
# Generate in OCI Console > User Settings > Auth Tokens.
OCIR_AUTH_TOKEN=[SOLICITAR A EQUIPA DE INFRA]
# Repository name under the tenancy (default: algoritmo-gd)
OCIR_REPO=algoritmo-gd
